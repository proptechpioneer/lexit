# Environment Configuration
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here
REFERRAL_BASE_URL=https://www.lexit.tech

# Email Configuration (Production)
# Configure these for production use on Railway
POSTMARK_SERVER_TOKEN=your-postmark-server-token
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=info@lexit.tech
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=info@lexit.tech
SERVER_EMAIL=info@lexit.tech

# ActiveCampaign (optional signup sync)
ACTIVECAMPAIGN_API_URL=https://youraccount.api-us1.com
ACTIVECAMPAIGN_API_KEY=your-activecampaign-api-key
ACTIVECAMPAIGN_DEFAULT_LIST_ID=
ACTIVECAMPAIGN_SIGNUP_TAG_ID=
ACTIVECAMPAIGN_REFERRAL_TAG_ID=
ACTIVECAMPAIGN_REFERRAL_CODE_TAG_PREFIX=ref=
ACTIVECAMPAIGN_REFERRER_NOTIFICATION_TAG_ID=
ACTIVECAMPAIGN_REFERRER_USER_ID_FIELD_NAME=Latest Referred User ID
ACTIVECAMPAIGN_REFERRER_CODE_FIELD_NAME=Latest Referral Code Used

# Example configurations for different email providers:

# Gmail:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-specific-password

# Postmark API (recommended):
# POSTMARK_SERVER_TOKEN=your-postmark-server-token

# Outlook/Hotmail:
# EMAIL_HOST=smtp-mail.outlook.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@outlook.com
# EMAIL_HOST_PASSWORD=your-password

# Amazon SES:
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-ses-access-key
# EMAIL_HOST_PASSWORD=your-ses-secret-key